# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environments
.env
.venv/
venv/
env/
ENV/

# Packaging and build artifacts
build/
.build-tmp/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Test and coverage artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Invarium local artifacts
.invarium/

# Temp files created by the manual test runner
_tmp_*/
_tmp_*.html
_tmp_*.py
_tmp_*.json

# Temporary pytest cache spillover seen on some Windows/OneDrive setups
pytest-cache-files-*/

# IDE and OS clutter
.DS_Store
Thumbs.db
